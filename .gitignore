# ==============================================================================
# JetBrains (Rider, WebStorm)
.idea/
*.sln.iml

# Visual Studio & VS Code
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# macOS & Windows
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/

